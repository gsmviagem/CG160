# ============================================================
# CG 160 — Environment Variables
# Copy this file to .env.local and fill in all values
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- AI Video Providers ---
RUNWAY_API_KEY=your-runway-api-key
KLING_API_KEY=your-kling-api-key
LUMA_API_KEY=your-luma-api-key

# Primary video provider: 'runway' | 'kling' | 'luma'
VIDEO_PROVIDER=runway

# --- Inngest (job queue) ---
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# --- Publishing ---
# TikTok
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token

# Instagram / Meta
INSTAGRAM_APP_ID=your-app-id
INSTAGRAM_APP_SECRET=your-app-secret
INSTAGRAM_ACCESS_TOKEN=your-long-lived-access-token
INSTAGRAM_ACCOUNT_ID=your-instagram-account-id

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your-cron-secret-for-securing-cron-routes

# --- Learning Loop ---
# Minimum videos before first weight adjustment
LEARNING_MIN_SAMPLE_SIZE=20
# EMA smoothing factor (0–1, lower = more conservative)
LEARNING_EMA_ALPHA=0.15
# Weight clamp bounds
LEARNING_WEIGHT_MIN=0.3
LEARNING_WEIGHT_MAX=3.0
# Anti-repetition cosine similarity threshold
IDEA_SIMILARITY_THRESHOLD=0.75

# --- Generation ---
# Min script score to proceed to video generation (0–100)
SCRIPT_MIN_SCORE_THRESHOLD=65
# Videos to generate per idea batch
IDEAS_PER_BATCH=10
SCRIPTS_PER_BATCH=5
